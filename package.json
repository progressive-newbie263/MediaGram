{
  "name": "mediagram",
  "version": "1.0.0",
  "private": true,
  "description": "MediaGram monorepo scripts",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:migrate": "npm run prisma:deploy --prefix backend",
    "db:seed": "npm run prisma:seed --prefix backend",
    "db:setup": "npm run setup --prefix backend",
    "dev:api": "npm run dev --prefix backend",
    "dev:web": "npm run dev --prefix frontend",
    "build:web": "npm run build --prefix frontend",
    "setup": "npm run install:all && npm run docker:up && npm run db:setup"
  }
}
